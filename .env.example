# ─── Solana Developer Platform — local compose ───────────────────────────────
# Copy to .env and fill in the values marked REQUIRED.
# See apps/sdp-api/docs/self-hosting/clerk-setup.md for Clerk walkthrough.

# ─── Host ports ───────────────────────────────────────────────────────────────
SDP_POSTGRES_PORT=5432
SDP_REDIS_PORT=6379
SDP_API_PORT=8787
SDP_WEB_PORT=3000
SDP_DOCS_PORT=3001

# ─── Core runtime ────────────────────────────────────────────────────────────
ENVIRONMENT=development
API_VERSION=local-compose

# self_hosted disables managed-tier enforcement so every configured provider is
# available regardless of the organization's tier.
SDP_DEPLOYMENT_MODE=self_hosted

# ─── Public URLs (browser-facing) ────────────────────────────────────────────
# Base origins (scheme + host[:port]), no trailing slash.
NEXT_PUBLIC_SDP_API_BASE_URL=http://localhost:8787
NEXT_PUBLIC_SDP_API_URL=http://localhost:8787
NEXT_PUBLIC_SDP_WEB_URL=http://localhost:3000
NEXT_PUBLIC_SDP_DOCS_URL=http://localhost:3001
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# ─── Authentication (Clerk) — REQUIRED ───────────────────────────────────────
# Get these from https://dashboard.clerk.com → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_with_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_replace_with_your_clerk_secret_key

# Clerk issuer — shown in Clerk Dashboard under API Keys → JWT Templates.
# Looks like https://<slug>.clerk.accounts.dev for dev instances.
CLERK_ISSUER=https://replace-with-your-instance.clerk.accounts.dev

# JWT template name — must match the template created in Clerk Dashboard.
# See apps/sdp-api/docs/self-hosting/clerk-setup.md step 3.
CLERK_JWT_TEMPLATE=sdp-api

# Clerk webhook signing secret — required for auto-provisioning organizations.
# Get from Clerk Dashboard → Webhooks → your endpoint → Signing Secret.
# Without this, organizations must be inserted into the DB manually.
# CLERK_WEBHOOK_SECRET=whsec_...

# ─── App secrets ─────────────────────────────────────────────────────────────
# Generate each with: openssl rand -hex 32
# API_KEY_PEPPER hashes API keys before storage; without it keys use no pepper.
# CUSTODY_ENCRYPTION_KEY encrypts org private keys in DB; without it keys are
# stored in plaintext.
# API_KEY_PEPPER=
# CUSTODY_ENCRYPTION_KEY=

# ─── Solana RPC ──────────────────────────────────────────────────────────────
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
# For mainnet, use a private RPC (Helius, Triton, Alchemy, QuickNode, etc.):
# SOLANA_RPC_HELIUS_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# SOLANA_RPC_HELIUS_API_KEY=YOUR_KEY

# ─── Signing provider ───────────────────────────────────────────────────────
# "local" keeps keys in this deployment; other options: fireblocks, privy,
# coinbase_cdp, para, turnkey, dfns, anchorage.
SIGNING_PROVIDER=local
# Base58 private key for the fee-payer wallet (required when SIGNING_PROVIDER=local).
# FEE_PAYER_PRIVATE_KEY=

# ─── Fee payment ─────────────────────────────────────────────────────────────
# "native" pays from FEE_PAYER_PRIVATE_KEY; "kora" delegates to a Kora node.
FEE_PAYMENT_PROVIDER=native

# ─── Observability (optional) ────────────────────────────────────────────────
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# ─── MagicBlock private payments (optional) ──────────────────────────────────
# MAGICBLOCK_PRIVATE_PAYMENTS_API_BASE_URL=https://payments.magicblock.app
# MAGICBLOCK_PRIVATE_PAYMENTS_AUTH_TOKEN=
