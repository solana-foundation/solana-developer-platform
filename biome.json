{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "semicolons": "always",
      "quoteStyle": "double",
      "trailingCommas": "es5"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error",
        "useExhaustiveDependencies": "warn"
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noImplicitAnyLet": "error",
        "noDoubleEquals": "error",
        "noConfusingVoidType": "error",
        "noAsyncPromiseExecutor": "error",
        "noUnsafeDeclarationMerging": "error",
        "noVar": "error"
      },
      "style": {
        "noNonNullAssertion": "warn",
        "useConst": "error"
      },
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "error",
          "options": {
            "maxAllowedComplexity": 30
          }
        },
        "noBannedTypes": "error",
        "noUselessTypeConstraint": "error"
      },
      "security": {
        "noDangerouslySetInnerHtml": "error",
        "noSecrets": "error"
      },
      "nursery": {}
    }
  },
  "overrides": [
    {
      "includes": ["**/src/openapi/**/*.ts", "**/apps/sdp-api/src/openapi/**/*.ts"],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          },
          "nursery": {},
          "security": {
            "noSecrets": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/apps/sdp-docs/scripts/generate-postman-collection.mjs",
        "**/scripts/generate-postman-collection.mjs"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          },
          "nursery": {},
          "security": {
            "noSecrets": "off"
          }
        }
      }
    },
    {
      "includes": ["**/issuance/templates/**/*.ts"],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          },
          "nursery": {},
          "security": {
            "noSecrets": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.test.js",
        "**/*.test.jsx",
        "**/test/**/*.ts",
        "**/test/**/*.tsx",
        "**/test/**/*.js",
        "**/test/**/*.jsx",
        "**/__tests__/**/*.ts",
        "**/__tests__/**/*.tsx",
        "**/__tests__/**/*.js",
        "**/__tests__/**/*.jsx"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          },
          "nursery": {},
          "security": {
            "noSecrets": "off"
          }
        }
      }
    }
  ],
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/.wrangler",
      "!**/.next",
      "!**/dist",
      "!**/*.d.ts",
      "!**/pnpm-lock.yaml",
      "!**/.source"
    ]
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  }
}
