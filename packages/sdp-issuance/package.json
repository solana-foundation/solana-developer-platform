    "@sdp/solana": "workspace:*",
    "@sdp/types": "workspace:*",
    "@solana-program/system": "catalog:",
    "@solana-program/token-2022": "catalog:",
    "@solana/kit": "catalog:",
    "@solana/mosaic-sdk": "catalog:",
    "@solana/signers": "catalog:",
    "@solana/token-acl-gate-sdk": "0.2.0"
  },
  "devDependencies": {
    "tsx": "4.22.4",
    "typescript": "^6.0.3"
