{
  "name": "@sdp/issuance",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./mosaic": {
      "types": "./src/mosaic/index.ts",
      "import": "./src/mosaic/index.ts",
      "default": "./src/mosaic/index.ts"
    },
    "./mosaic/service": {
      "types": "./src/mosaic/service.ts",
      "import": "./src/mosaic/service.ts",
      "default": "./src/mosaic/service.ts"
    },
    "./mosaic/types": {
      "types": "./src/mosaic/types.ts",
      "import": "./src/mosaic/types.ts",
      "default": "./src/mosaic/types.ts"
    },
    "./mosaic/utils": {
      "types": "./src/mosaic/utils.ts",
      "import": "./src/mosaic/utils.ts",
      "default": "./src/mosaic/utils.ts"
    },
    "./capabilities": {
      "types": "./src/capabilities/index.ts",
      "import": "./src/capabilities/index.ts",
      "default": "./src/capabilities/index.ts"
    },
    "./templates": {
      "types": "./src/templates/index.ts",
      "import": "./src/templates/index.ts",
      "default": "./src/templates/index.ts"
    },
    "./templates/definitions": {
      "types": "./src/templates/definitions.ts",
      "import": "./src/templates/definitions.ts",
      "default": "./src/templates/definitions.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
