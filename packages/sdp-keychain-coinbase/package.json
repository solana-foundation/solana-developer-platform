{
  "name": "@sdp/keychain-coinbase",
  "version": "0.1.0",
  "private": true,
  "description": "Temporary internal Coinbase CDP signer for Solana keychain compatibility",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@solana/addresses": "catalog:",
    "@solana/codecs": "catalog:",
    "@solana/codecs-strings": "^5.0.0",
    "@solana/keychain-core": "0.3.0",
    "@solana/keys": "catalog:",
    "@solana/signers": "catalog:",
    "@solana/transactions": "^5.0.0",
    "jose": "^6.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.18.8",
    "dotenv": "^17.2.3",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
