{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", ".env.*"],
  "globalEnv": [
    "API_KEY_PEPPER",
    "CLERK_JWT_TEMPLATE",
    "CLERK_SECRET_KEY",
    "CUSTODY_PRIVATE_KEY",
    "KORA_API_KEY",
    "KORA_MIN_BALANCE_LAMPORTS",
    "KORA_RPC_URL",
    "KORA_TIMEOUT_MS",
    "NEXT_PUBLIC_API_BASE_URL",
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_SDP_API_BASE_URL",
    "RUN_INTEGRATION_TESTS",
    "SDP_API_BASE_URL",
    "SOLANA_NETWORK",
    "SOLANA_RPC_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:local": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    }
  }
}
