{
  "name": "solana-developer-platform",
  "version": "0.43.1",
  "private": true,
  "packageManager": "pnpm@10.16.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.16.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@solana/kit": "^6.5.0"
      }
    },
    "overrides": {
      "@token-acl/abl-sdk": "npm:@solana/token-acl-gate-sdk@0.2.0",
      "fast-uri": "^3.1.3",
      "postcss": "^8.5.10"
    },
    "patchedDependencies": {
      "@solana/mosaic-sdk@0.1.1": "patches/@solana__mosaic-sdk@0.1.1.patch",
      "next-themes@0.4.6": "patches/next-themes@0.4.6.patch"
    }
  },
  "scripts": {
    "dev": "scripts/doppler/run-with-config.sh turbo run dev:local dev:db dev:webhook --env-mode=loose",
    "dev:webhooks": "scripts/doppler/run-with-config.sh turbo run dev:webhook --env-mode=loose",
    "dev:web": "scripts/doppler/run-with-config.sh turbo run dev --filter=sdp-web --env-mode=loose",
    "dev:docs": "scripts/doppler/run-with-config.sh turbo run dev --filter=sdp-docs --env-mode=loose",
    "dev:docs:bare": "turbo run dev --filter=sdp-docs",
    "dev:api": "scripts/doppler/run-with-config.sh turbo run dev --filter=@sdp/api --env-mode=loose",
    "dev:api:local": "scripts/doppler/run-with-config.sh turbo run dev:local --filter=@sdp/api --env-mode=loose",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=sdp-web",
    "build:docs": "turbo run build --filter=sdp-docs",
    "build:api": "turbo run build --filter=@sdp/api",
    "check:env-contract": "node scripts/check-env-contract.mjs",
    "check:env-configurator-drift": "node scripts/check-env-configurator-drift.mjs",
    "check:module-boundaries": "node scripts/check-module-boundaries.mjs",
    "generate:module-map": "node scripts/check-module-boundaries.mjs --write",
    "typecheck": "turbo run typecheck",
    "typecheck:all": "turbo run typecheck",
    "lint": "biome check .",
    "lint:all": "turbo run lint",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "scripts/doppler/run-with-config.sh node scripts/run-workspace-tests.mjs unit",
    "test:integration": "scripts/doppler/run-with-config.sh node scripts/run-workspace-tests.mjs integration",
    "test:scripts": "node --test scripts/*.test.mjs",
    "secrets:print:docker": "node scripts/project-secrets.mjs docker",
    "check": "biome check --write . && turbo run typecheck",
    "db:postgres:up": "docker compose -f infra/postgres/docker-compose.yml up -d",
    "db:postgres:down": "docker compose -f infra/postgres/docker-compose.yml down",
    "db:postgres:reset": "docker compose -f infra/postgres/docker-compose.yml down -v && docker compose -f infra/postgres/docker-compose.yml up -d",
    "db:postgres:logs": "docker compose -f infra/postgres/docker-compose.yml logs -f postgres",
    "kora:up": "docker compose -f infra/kora/docker-compose.yml up -d",
    "kora:down": "docker compose -f infra/kora/docker-compose.yml down",
    "kora:logs": "docker compose -f infra/kora/docker-compose.yml logs -f kora",
    "kora:surfpool:up": "scripts/kora-surfpool/up.sh",
    "kora:surfpool:down": "scripts/kora-surfpool/down.sh",
    "kora:surfpool:run": "scripts/kora-surfpool/run.sh",
    "kora:surfpool:e2e:issuance": "scripts/kora-surfpool/e2e-issuance.sh",
    "kora:surfpool:integration": "scripts/kora-surfpool/integration.sh",
    "kora:surfpool:test": "scripts/kora-surfpool/test.sh",
    "kora:devnet:check": "infra/kora/cloud-run/check.sh",
    "kora:devnet:test": "DATABASE_URL=${KORA_DEVNET_DATABASE_URL:-${DATABASE_URL:-postgresql://sdp:sdp@127.0.0.1:5432/sdp}} node scripts/run-workspace-tests.mjs integration -- src/tests/kora.test.ts src/tests/kora-flow.test.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "turbo": "^2.9.17",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@solana/rpc-spec": "6.5.0",
    "@solana/kit": "6.5.0"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@solana-program/system": "^0.12.0",
      "@solana-program/token-2022": "^0.9.0",
      "@solana/addresses": "^6.5.0",
      "@solana/codecs": "^6.5.0",
      "@solana/instructions": "^6.5.0",
      "@solana/keys": "^6.5.0",
      "@solana/kit": "^6.5.0",
      "@solana/mosaic-sdk": "0.1.1",
      "@solana/programs": "^6.5.0",
      "@solana/rpc": "^6.5.0",
      "@solana/signers": "^6.5.0",
      "@solana/sysvars": "^6.5.0",
      "@solana/transactions": "^6.5.0"
    }
  }
}
