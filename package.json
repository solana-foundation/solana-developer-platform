{
  "name": "solana-developer-platform",
  "version": "0.10.0",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@solana/kit": "^5.0.0"
      }
    }
  },
  "scripts": {
    "dev": "turbo run dev:local",
    "dev:web": "turbo run dev --filter=sdp-web",
    "dev:docs": "turbo run dev --filter=sdp-docs",
    "dev:api": "turbo run dev --filter=@sdp/api",
    "dev:api:local": "turbo run dev:local --filter=@sdp/api",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=sdp-web",
    "build:docs": "turbo run build --filter=sdp-docs",
    "build:api": "turbo run build --filter=@sdp/api",
    "typecheck": "turbo run typecheck",
    "typecheck:all": "turbo run typecheck",
    "lint": "biome check .",
    "lint:all": "turbo run lint",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "turbo run test --filter=!@sdp/api-integration",
    "test:integration": "turbo run test --filter=@sdp/api-integration",
    "check": "biome check --write . && turbo run typecheck",
    "kora:up": "docker compose -f infra/kora/docker-compose.yml up -d",
    "kora:down": "docker compose -f infra/kora/docker-compose.yml down",
    "kora:logs": "docker compose -f infra/kora/docker-compose.yml logs -f kora",
    "kora:devnet:check": "infra/kora/cloud-run/check.sh",
    "kora:devnet:test": "pnpm --filter @sdp/api-integration test -- src/tests/kora.test.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "turbo": "^2.4.0",
    "typescript": "^5.8.0"
  },
  "overrides": {
    "@solana/rpc-spec": "5.0.0",
    "@solana/kit": "5.0.0"
  },
  "workspaces": {
    "packages": ["apps/*", "packages/*"],
    "catalog": {
      "@solana-program/system": "^0.10.0",
      "@solana-program/token-2022": "^0.6.1",
      "@solana/addresses": "^5.0.0",
      "@solana/codecs": "^5.0.0",
      "@solana/instructions": "^5.0.0",
      "@solana/keys": "^5.0.0",
      "@solana/kit": "^5.0.0",
      "@solana/mosaic-sdk": "0.1.1",
      "@solana/programs": "^5.0.0",
      "@solana/rpc": "^5.0.0",
      "@solana/signers": "^5.0.0",
      "@solana/sysvars": "^5.0.0",
      "@solana/transactions": "^5.0.0"
    }
  }
}
