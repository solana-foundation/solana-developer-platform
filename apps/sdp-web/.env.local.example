# SDP Web local environment (copy to .env.local)

# Clerk authentication (required) — get from https://dashboard.clerk.com
# Self-hosted setup walkthrough: apps/sdp-api/docs/self-hosting/clerk-setup.md
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# JWT template name (must match a template configured in the Clerk dashboard).
# A custom template is required because Clerk's default session token omits org_id.
CLERK_JWT_TEMPLATE=sdp-api

# SDP API endpoint (required)
NEXT_PUBLIC_SDP_API_BASE_URL=http://127.0.0.1:8787

# Feature flags (optional) — set to "true" to enable.
# Asset Profiles issuance UI (full-page create wizard). The sdp-api backend
# flag ASSET_PROFILES_ENABLED must also be enabled for the feature to work.
NEXT_PUBLIC_ASSET_PROFILES_ENABLED=

# Error tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
