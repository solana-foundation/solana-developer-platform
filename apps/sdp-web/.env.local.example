# SDP Web local environment (copy to .env.local)

# Clerk authentication (required) — get from https://dashboard.clerk.com
# Self-hosted setup walkthrough: apps/sdp-api/docs/self-hosting/clerk-setup.md
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# JWT template name (must match a template configured in the Clerk dashboard).
# A custom template is required because Clerk's default session token omits org_id.
CLERK_JWT_TEMPLATE=sdp-api

# Optional Clerk routing overrides (defaults work for local dev)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# SDP API endpoint (required)
NEXT_PUBLIC_SDP_API_BASE_URL=http://127.0.0.1:8787
# Optional server-side override for BFF routes (defaults to the public URL above)
# SDP_API_BASE_URL=http://127.0.0.1:8787

# Docs site URL for in-dashboard documentation links (optional)
# NEXT_PUBLIC_SDP_DOCS_URL=http://localhost:3001

# Error tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
