{
  "name": "@sdp/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:local": "wrangler dev --local --persist-to=.wrangler/state",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "deploy:dev": "wrangler deploy --env dev",
    "deploy:production": "wrangler deploy --env production",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:dev": "wrangler d1 migrations apply DB --env dev --remote",
    "db:migrate:production": "wrangler d1 migrations apply DB --env production --remote",
    "db:seed:local": "wrangler d1 execute DB --local --file=src/db/seed.sql",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@react-email/components": "1.0.6",
    "@react-email/render": "2.0.4",
    "@sdp/keychain-coinbase": "workspace:*",
    "@sdp/keychain-para": "workspace:*",
    "@sdp/types": "workspace:*",
    "@sentry/cloudflare": "^10.42.0",
    "@solana-program/system": "catalog:",
    "@solana-program/token-2022": "catalog:",
    "@solana/addresses": "catalog:",
    "@solana/codecs": "catalog:",
    "@solana/keychain-core": "0.3.0",
    "@solana/keychain-fireblocks": "0.2.1",
    "@solana/keychain-privy": "0.3.0",
    "@solana/keychain-turnkey": "0.3.0",
    "@solana/kit": "catalog:",
    "@solana/kora": "0.1.2",
    "@solana/mosaic-sdk": "catalog:",
    "@solana/signers": "catalog:",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.7.0",
    "jose": "^6.1.3",
    "nanoid": "^5.1.0",
    "react": "19.2.3",
    "svix": "1.84.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "7.2.0",
    "@cloudflare/vitest-pool-workers": "^0.12.0",
    "@cloudflare/workers-types": "^4.20250124.0",
    "@vitest/coverage-v8": "^3.0.0",
    "drizzle-kit": "^0.31.8",
    "openapi3-ts": "4.5.0",
    "tsx": "4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.1.0"
  }
}
