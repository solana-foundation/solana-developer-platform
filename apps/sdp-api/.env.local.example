# SDP API local environment (copy to .env.local)

# --- Database ---
# Defaults to the local Docker Postgres; point at any postgresql:// connection
# string to use an external database.
# DATABASE_URL=postgresql://sdp:sdp@127.0.0.1:5432/sdp

# Defaults to the local Docker Redis instance. Use a dedicated database or
# instance for any shared environment.
# REDIS_URL=redis://127.0.0.1:6379

# Public origin used in permanent on-chain metadata URLs. Local development
# defaults to the incoming request origin; set this when requests arrive through
# a proxy or tunnel whose public host/scheme differs from the local listener.
# PUBLIC_API_ORIGIN=http://localhost:8787

# Embedded reconciliation cron is enabled by default outside Cloud Run. Disable
# it when a separate scheduler owns reconciliation; "false" or "0" opts in.
# DISABLE_CRON=true

# Optional: explicit test-database URL used by
# `pnpm --filter @sdp/api db:migrate:test`. API unit tests provision isolated
# Postgres and Redis containers automatically.
# TEST_DATABASE_URL=postgresql://sdp:sdp@127.0.0.1:5432/sdp_test

# --- Deployment mode ---
# "managed" (default; uses Clerk-synced org tier entitlements)
# or "self_hosted" (every configured provider is automatically entitled
# regardless of tier). Per-org providerOverrides still apply as a disable-only
# mechanism.
# SDP_DEPLOYMENT_MODE=self_hosted

# --- Minimum self-hosted set (no third-party provider dependencies) ---
# Uncomment these alongside SDP_DEPLOYMENT_MODE=self_hosted to run with
# only the local signer + native fee payment + a single RPC endpoint.
#
# Custody: local signer
# Generate keypair + encryption key values with: pnpm --filter @sdp/api keygen:local
# SIGNING_PROVIDER=local
# CUSTODY_PRIVATE_KEY=<base58-encoded keypair>
# CUSTODY_ENCRYPTION_KEY=<base64-encoded 256-bit key>  # required for any custody provider — encrypts stored wallet secrets
# CUSTODY_KMS_KEY_NAME=projects/<project>/locations/<location>/keyRings/<ring>/cryptoKeys/<key>  # optional — routes custody encryption through Cloud KMS envelope encryption (keep CUSTODY_ENCRYPTION_KEY to read existing rows)
#
# Fee payment: native (Use it if you don't want to use Kora — that points at the Solana Foundation's
# public endpoint and adds an external dependency. Defaults to "kora" when unset.)
# FEE_PAYMENT_PROVIDER=native
# FEE_PAYER_PRIVATE_KEY=<base58-encoded keypair>
#
# RPC: any single endpoint. Avoid the public https://api.devnet.solana.com —
# it 403s getTokenAccountsByOwner, which breaks wallet balances. Use a free
# Helius / Triton / QuickNode key or a local solana-test-validator instead.
# SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=<your-key>

# --- Observability ---
# SENTRY_DSN=https://examplePublicKey@o0.ingest.us.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=1.0

# --- Managed-mode defaults ---
# These are the defaults for the hosted Solana Foundation deployment.
# If you are running self-hosted (SDP_DEPLOYMENT_MODE=self_hosted), comment
# every var in this section out — otherwise SOLANA_RPC_URL and
# FEE_PAYMENT_PROVIDER below will silently override the self-hosted block above
# and re-introduce the external dependencies that mode is meant to avoid.

# Solana RPC (devnet). Keep provider URLs templated and put credentials in the
# *_API_KEY vars below so deploys do not carry live keys in plain text.
# SOLANA_NETWORK=devnet  (code defaults to devnet when unset)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_RPC_DEFAULT_PROVIDER=helius
SOLANA_RPC_ALCHEMY_URL=https://solana-devnet.g.alchemy.com/v2/{API_KEY}
SOLANA_RPC_TRITON_URL=https://solanaf-sdp-7436.devnet.rpcpool.com/{API_KEY}
SOLANA_RPC_HELIUS_URL=https://devnet.helius-rpc.com/?api-key={API_KEY}
SOLANA_RPC_NODIT_URL=https://solana-devnet.nodit.io/{API_KEY}
SOLANA_RPC_QUICKNODE_URL=https://evocative-old-mansion.solana-devnet.quiknode.pro/{API_KEY}
SOLANA_RPC_VALIDATIONCLOUD_URL=https://devnet.solana.validationcloud.io/v1/{API_KEY}
# Managed RPC providers for proxy round-robin.
# For live connectivity tests, configure all provider URLs above.
# SOLANA_RPC_TRITON_API_KEY=YOUR_TRITON_KEY
# SOLANA_RPC_HELIUS_API_KEY=YOUR_HELIUS_KEY
# SOLANA_RPC_NODIT_API_KEY=YOUR_NODIT_KEY
# SOLANA_RPC_ALCHEMY_API_KEY=YOUR_ALCHEMY_KEY
# SOLANA_RPC_QUICKNODE_API_KEY=YOUR_QUICKNODE_KEY
# SOLANA_RPC_VALIDATIONCLOUD_API_KEY=YOUR_VALIDATIONCLOUD_KEY

# Shared devnet Kora instance for managed-mode fee payment.
KORA_RPC_URL=https://your-kora-devnet-instance.us-central1.run.app
# KORA_API_KEY=YOUR_KORA_API_KEY (only if API key auth is enabled)
FEE_PAYMENT_PROVIDER=kora
# --- end managed-mode defaults ---

# --- Custody signers ---
# One group per SIGNING_PROVIDER value; configure only the provider(s) you use.

# Coinbase CDP platform signer (required for coinbase_cdp custody provider)
# SIGNING_PROVIDER=coinbase_cdp
# COINBASE_CDP_API_KEY_ID=YOUR_CDP_API_KEY_ID
# COINBASE_CDP_API_KEY_SECRET=-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----
# COINBASE_CDP_WALLET_SECRET=BASE64_PKCS8_DER_WALLET_SECRET
# COINBASE_CDP_API_BASE_URL=https://api.cdp.coinbase.com/platform
# COINBASE_CDP_NETWORK=solana-devnet
# COINBASE_CDP_WALLET_ID=YOUR_DEFAULT_CDP_SOLANA_ADDRESS

# Para platform signer (required for para custody provider)
# SIGNING_PROVIDER=para
# PARA_API_KEY=YOUR_PARA_API_KEY
# PARA_API_BASE_URL=https://api.getpara.com
# PARA_REQUEST_DELAY_MS=0
# PARA_WALLET_ID=YOUR_DEFAULT_PARA_WALLET_ID

# Turnkey platform signer (required for turnkey custody provider)
# SIGNING_PROVIDER=turnkey
# TURNKEY_API_PUBLIC_KEY=YOUR_TURNKEY_API_PUBLIC_KEY_HEX
# TURNKEY_API_PRIVATE_KEY=YOUR_TURNKEY_API_PRIVATE_KEY_HEX
# TURNKEY_ORGANIZATION_ID=YOUR_TURNKEY_ORGANIZATION_ID
# TURNKEY_API_BASE_URL=https://api.turnkey.com
# TURNKEY_REQUEST_DELAY_MS=0
# TURNKEY_PRIVATE_KEY_ID=YOUR_DEFAULT_TURNKEY_PRIVATE_KEY_ID
# TURNKEY_PUBLIC_KEY=YOUR_DEFAULT_TURNKEY_SOLANA_PUBLIC_KEY

# Utila platform signer (registers existing Utila Solana wallets)
# SIGNING_PROVIDER=utila
# UTILA_SERVICE_ACCOUNT_EMAIL=your-service-account@vault.utilaserviceaccount.io
# UTILA_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# UTILA_VAULT_ID=YOUR_UTILA_VAULT_ID
# UTILA_WALLET_ID=YOUR_DEFAULT_UTILA_WALLET_ID
# UTILA_NETWORK=networks/solana-devnet
# UTILA_API_BASE_URL=https://api.utila.io
# UTILA_POLL_INTERVAL_MS=1000
# UTILA_MAX_POLL_ATTEMPTS=60
# Automated Utila signer resources. Omit to default to users/$UTILA_SERVICE_ACCOUNT_EMAIL.
# UTILA_DESIGNATED_SIGNERS=users/your-service-account@vault.utilaserviceaccount.io

# IBM Digital Asset Haven platform signer (required for ibm_haven custody provider)
# SIGNING_PROVIDER=ibm_haven
# IBM_HAVEN_AUTH_TOKEN=YOUR_IBM_HAVEN_AUTH_TOKEN
# IBM_HAVEN_CREDENTIAL_ID=YOUR_IBM_HAVEN_CREDENTIAL_ID
# IBM_HAVEN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# IBM_HAVEN_API_BASE_URL=https://api.digitalassets.ibm.com
# IBM_HAVEN_WALLET_ID=YOUR_DEFAULT_IBM_HAVEN_WALLET_ID

# Privy platform signer (required for privy custody provider)
# SIGNING_PROVIDER=privy
# PRIVY_APP_ID=YOUR_PRIVY_APP_ID
# PRIVY_APP_SECRET=YOUR_PRIVY_APP_SECRET
# PRIVY_API_BASE_URL=https://api.privy.io
# PRIVY_REQUEST_DELAY_MS=0
# PRIVY_WALLET_ID=YOUR_DEFAULT_PRIVY_WALLET_ID

# Fireblocks platform signer (required for fireblocks custody provider)
# SIGNING_PROVIDER=fireblocks
# FIREBLOCKS_API_KEY=YOUR_FIREBLOCKS_API_KEY
# FIREBLOCKS_API_SECRET="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# FIREBLOCKS_API_BASE_URL=https://api.fireblocks.io
# FIREBLOCKS_ASSET_ID=SOL_TEST
# FIREBLOCKS_VAULT_ID=YOUR_FIREBLOCKS_VAULT_ID

# Dfns platform signer (required for dfns custody provider)
# SIGNING_PROVIDER=dfns
# DFNS_AUTH_TOKEN=YOUR_DFNS_AUTH_TOKEN
# DFNS_CREDENTIAL_ID=YOUR_DFNS_CREDENTIAL_ID
# DFNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# DFNS_API_BASE_URL=https://api.dfns.io
# DFNS_WALLET_ID=YOUR_DEFAULT_DFNS_WALLET_ID

# --- Clerk auth + webhook ---
# See docs/self-hosting/clerk-setup.md for the end-to-end walkthrough
# (account creation, JWT template, webhook relay via ngrok).
#
# Issuer URL — find in Clerk dashboard → API Keys (e.g. https://<slug>.clerk.accounts.dev)
CLERK_ISSUER=
# Optional: only set if you configure an `aud` claim in the JWT template
# CLERK_AUDIENCE=
# Optional: defaults to ${CLERK_ISSUER}/.well-known/jwks.json
# CLERK_JWKS_URL=
# Webhook signing secret from the Clerk endpoint that points at /webhooks/clerk/link-orgs
CLERK_WEBHOOK_SECRET=whsec_...
# Backend API key (dashboard → API Keys) — used for Clerk org/user lookups
CLERK_SECRET_KEY=sk_test_...
# Publishable key (dashboard → API Keys) — used by Playwright e2e when not
# running under Doppler
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# --- App config ---
# Reserved ngrok domain used by `pnpm dev:webhooks` — one stable URL for all
# provider webhooks in local dev. Reserve free at https://dashboard.ngrok.com/domains
# WEBHOOK_INGEST_DOMAIN=your-subdomain.ngrok-free.dev
# Base URL for dashboard links generated by the API (e.g. member invites)
# FRONTEND_URL=http://localhost:3000
# Google Places address completion (counterparty address forms)
# GOOGLE_ADDRESS_COMPLETION_API_KEY=YOUR_GOOGLE_PLACES_API_KEY

# --- Compliance providers ---
# RANGE_API_KEY=YOUR_RANGE_API_KEY
# RANGE_API_BASE_URL=https://api.range.org
# ELLIPTIC_API_TOKEN=YOUR_ELLIPTIC_BEARER_TOKEN
# ELLIPTIC_API_KEY=YOUR_ELLIPTIC_API_KEY
# ELLIPTIC_API_SECRET=YOUR_ELLIPTIC_API_SECRET_BASE64
# ELLIPTIC_API_BASE_URL=https://aml-api.elliptic.co
# TRM_API_KEY=YOUR_TRM_API_KEY
# TRM_API_BASE_URL=https://api.trmlabs.com
# CHAINALYSIS_API_KEY=YOUR_CHAINALYSIS_API_KEY
# CHAINALYSIS_API_BASE_URL=https://api.chainalysis.com

# --- Ramp providers ---
# Each provider has prod-named vars and *_SANDBOX_* variants; test-mode wallets
# use the sandbox credentials, live wallets use the prod ones. Configure either
# set (or both) — a provider with neither is reported unavailable.

# MoonPay ramps (widget-based)
# MOONPAY_API_KEY=pk_live_...
# MOONPAY_SECRET_KEY=sk_live_...
# MOONPAY_WEBHOOK_KEY=YOUR_MOONPAY_WEBHOOK_KEY
# MOONPAY_SANDBOX_API_KEY=pk_test_...
# MOONPAY_SANDBOX_SECRET_KEY=sk_test_...
# MOONPAY_SANDBOX_WEBHOOK_KEY=YOUR_MOONPAY_SANDBOX_WEBHOOK_KEY

# Lightspark Grid ramps (API-based)
# LIGHTSPARK_GRID_CLIENT_ID=YOUR_LIGHTSPARK_TOKEN_ID
# LIGHTSPARK_GRID_CLIENT_SECRET=YOUR_LIGHTSPARK_CLIENT_SECRET
# LIGHTSPARK_GRID_WEBHOOK_PUBLIC_KEY=YOUR_LIGHTSPARK_WEBHOOK_PUBLIC_KEY_HEX
# LIGHTSPARK_GRID_SANDBOX_CLIENT_ID=YOUR_LIGHTSPARK_SANDBOX_TOKEN_ID
# LIGHTSPARK_GRID_SANDBOX_CLIENT_SECRET=YOUR_LIGHTSPARK_SANDBOX_CLIENT_SECRET
# LIGHTSPARK_GRID_SANDBOX_WEBHOOK_PUBLIC_KEY=YOUR_LIGHTSPARK_SANDBOX_WEBHOOK_PUBLIC_KEY_HEX

# BVNK ramps (API-based, Hawk auth only)
# BVNK_HAWK_AUTH_ID=YOUR_BVNK_HAWK_AUTH_ID
# BVNK_HAWK_SECRET_KEY=YOUR_BVNK_HAWK_SECRET_KEY
# BVNK_WALLET_ID=YOUR_BVNK_WALLET_ID
# BVNK_WEBHOOK_SECRET=YOUR_BVNK_WEBHOOK_SIGNING_SECRET
# Sandbox variants
# BVNK_SANDBOX_HAWK_AUTH_ID=YOUR_BVNK_SANDBOX_HAWK_AUTH_ID
# BVNK_SANDBOX_HAWK_SECRET_KEY=YOUR_BVNK_SANDBOX_HAWK_SECRET_KEY
# BVNK_SANDBOX_WALLET_ID=YOUR_BVNK_SANDBOX_WALLET_ID
# BVNK_SANDBOX_WEBHOOK_SECRET=YOUR_BVNK_SANDBOX_WEBHOOK_SIGNING_SECRET
# Note: BVNK on-ramp can require additional provider-side enablement/compliance setup
# beyond API credentials (for example pay-in permissions on your merchant account).

# BVNK static-egress proxy (optional; leave all three unset for direct BVNK access)
# BVNK requires requests to come from a stable IP allowlisted on your merchant
# account. If the API's egress is not already stable, route BVNK traffic through
# a reverse proxy with a fixed address and point BVNK_API_BASE_URL at it.
# BVNK_API_BASE_URL=https://your-bvnk-proxy.example.com
# Real BVNK host used for Hawk signing when BVNK_API_BASE_URL is a proxy
# (defaults to the sandbox/prod BVNK host).
# BVNK_SIGNING_HOST=api.sandbox.bvnk.com
# Shared secret sent as the X-Proxy-Auth header (the proxy returns 403 without it).
# PROXY_SHARED_SECRET=YOUR_PROXY_SHARED_SECRET

# MoneyGram ramps (sandbox only for now)
# MONEYGRAM_SANDBOX_PUBLIC_KEY=YOUR_MONEYGRAM_SANDBOX_PUBLIC_KEY
# MONEYGRAM_SANDBOX_SECRET_KEY=YOUR_MONEYGRAM_SANDBOX_SECRET_KEY

# Mural Pay ramps (API-based)
# MURAL_PAY_API_KEY=YOUR_MURAL_PAY_API_KEY
# MURAL_PAY_TRANSFER_API_KEY=YOUR_MURAL_PAY_TRANSFER_API_KEY
# MURAL_PAY_WEBHOOK_PUBLIC_KEY=YOUR_MURAL_PAY_WEBHOOK_PUBLIC_KEY
# MURAL_PAY_SANDBOX_API_KEY=YOUR_MURAL_PAY_SANDBOX_API_KEY
# MURAL_PAY_SANDBOX_TRANSFER_API_KEY=YOUR_MURAL_PAY_SANDBOX_TRANSFER_API_KEY
# MURAL_PAY_SANDBOX_WEBHOOK_PUBLIC_KEY=YOUR_MURAL_PAY_SANDBOX_WEBHOOK_PUBLIC_KEY

# Stripe ramps (crypto onramp; test keys act as the sandbox)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
