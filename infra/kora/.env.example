# Kora Environment Variables
# Copy to .env and fill in values

# Solana RPC URL (devnet for local development)
RPC_URL=https://api.devnet.solana.com

# Fee payer private key (base58 encoded, 64-byte keypair)
# Generate with: solana-keygen new --no-bip39-passphrase -o /dev/stdout | tail -1
# IMPORTANT: Fund this account with devnet SOL: solana airdrop 2 <ADDRESS> --url devnet
SIGNER_PRIVATE_KEY=your_base58_private_key_here
